{
  "name": "ts-express-rest-skeleton",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "node --import tsx --test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "gts:lint": "gts lint",
    "gts:fix": "gts fix",
    "prepare": "gts fix"
  },
  "dependencies": {
    "express": "^4.18.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "gts": "^6.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0"
  }
}
