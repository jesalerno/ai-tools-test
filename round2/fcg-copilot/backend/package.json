{
  "name": "fcg-copilot-backend",
  "version": "1.0.0",
  "description": "Fractal Card Generator — Backend API",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "build": "tsc --noEmit false",
    "dev": "node --watch --loader ts-node/esm src/infrastructure/server.ts",
    "start": "node dist/infrastructure/server.js",
    "lint": "eslint --max-warnings 0 .",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "test:live": "CANVAS_LIVE=true node --experimental-vm-modules node_modules/.bin/jest --coverage"
  },
  "dependencies": {
    "@napi-rs/canvas": "0.1.57",
    "ajv": "8.17.1",
    "complex.js": "2.4.2",
    "cors": "2.8.5",
    "express": "5.1.0",
    "express-rate-limit": "7.5.0",
    "uuid": "11.0.5"
  },
  "devDependencies": {
    "@eslint/js": "9.27.0",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.3",
    "@types/jest": "29.5.14",
    "@types/node": "20.17.57",
    "@types/supertest": "6.0.3",
    "@types/uuid": "10.0.0",
    "eslint": "9.27.0",
    "jest": "29.7.0",
    "supertest": "7.1.0",
    "ts-jest": "29.3.4",
    "ts-node": "10.9.2",
    "typescript": "5.8.3",
    "typescript-eslint": "8.33.0"
  }
}
