{
  "name": "fcg-claude-backend",
  "version": "1.0.0",
  "description": "Fractal Card Generator backend (fcg-claude).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20 <21"
  },
  "main": "dist/server.js",
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --check .",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "node --watch --loader ts-node/esm src/server.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.cjs",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.cjs --coverage"
  },
  "dependencies": {
    "@napi-rs/canvas": "0.1.65",
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "complex.js": "2.4.2",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "5.1.0",
    "express-rate-limit": "7.5.0",
    "swagger-ui-express": "5.0.1",
    "uuid": "11.0.5"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/jest": "29.5.14",
    "@types/node": "20.17.10",
    "@types/supertest": "6.0.2",
    "@types/swagger-ui-express": "4.1.7",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/eslint-plugin": "8.46.2",
    "@typescript-eslint/parser": "8.46.2",
    "eslint": "9.37.0",
    "eslint-config-prettier": "10.1.8",
    "jest": "29.7.0",
    "prettier": "3.6.2",
    "supertest": "7.1.4",
    "ts-jest": "29.4.4",
    "ts-node": "10.9.2",
    "typescript": "5.9.2",
    "typescript-eslint": "8.46.2"
  }
}
