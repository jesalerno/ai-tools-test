  "devDependencies": {
    "typescript": "5.9.3",
    "eslint": "9.0.0",
    "typescript-eslint": "8.0.0",
    "@types/express": "5.0.0",
    "@types/cors": "2.8.17",
    "@types/jest": "29.5.12",
    "jest": "29.7.0",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2"
