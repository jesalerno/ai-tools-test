{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "outDir": "./dist",
    "rootDir": ".."
  },
  "include": ["src", "../shared"]
}
