{
  "openapi": "3.0.3",
  "info": {
    "title": "Fractal Card Generator API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/health": {
      "get": {
        "responses": {
          "200": {
            "description": "Service healthy"
          }
        }
      }
    },
    "/api/cards/generate": {
      "post": {
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "method": { "type": "string" },
                  "seed": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Generated card" },
          "400": { "description": "Validation error" },
          "500": { "description": "Server error" }
        }
      }
    }
  }
}
